# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment secrets - NEVER commit
.env
.env.local
.env.production
*.env

# API Keys and secrets
**/local.properties
**/key.properties
**/secrets.properties
*.p12
*.mobileprovision
*.jks
*.keystore

# Firebase runtime configs - managed by CI/CD secrets (never commit)
**/google-services.json
**/google-services-dev.json
**/google-services-prod.json
**/google-services.json-*
**/GoogleService-Info.plist
**/GoogleService-Info-Dev.plist
**/GoogleService-Info-Prod.plist

# Firebase env dart configs ARE committed (safe — security via Firebase rules)
# lib/env/firebase_options_dev.dart  ← committed
# lib/env/firebase_options_prod.dart ← committed
