# MajuRun Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Environment (development/production)
ENVIRONMENT=development

# Cloudinary (required for media uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Weather API (optional)
WEATHER_API_KEY=your_openweathermap_key

# Google Maps (optional - uses native config if empty)
GOOGLE_MAPS_KEY=your_google_maps_key

# ReCAPTCHA (optional - has default)
RECAPTCHA_KEY=your_recaptcha_site_key

# API Base URL (optional)
API_BASE_URL=https://api.majurun.com
