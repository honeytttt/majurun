# Release signing configuration for Google Play Store
# Copy this file to key.properties and fill in your values
# DO NOT commit key.properties to version control!

# Path to your keystore file (relative to android folder or absolute path)
storeFile=majurun-release.jks

# Keystore password
storePassword=YOUR_KEYSTORE_PASSWORD

# Key alias name
keyAlias=majurun

# Key password (often same as keystore password)
keyPassword=YOUR_KEY_PASSWORD
