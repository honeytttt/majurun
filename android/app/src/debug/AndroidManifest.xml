<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-only manifest — merged on top of main AndroidManifest.xml for debug builds only.
  The App Check debug secret is safe to commit:
    - Only active when using AndroidProvider.debug (debug builds)
    - Registered once in Firebase Console, works on every dev machine permanently
    - Production builds use Play Integrity — this token is ignored
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <!--
          Fixed App Check debug token.
          REGISTER THIS ONCE:
          Firebase Console → App Check → Apps → com.majurun.app → Manage debug tokens
          → Add token: 8C9D138D-5253-47E4-B45F-0A4C4EF7D9FC
        -->
        <meta-data
            android:name="firebase_app_check_debug_secret"
            android:value="8C9D138D-5253-47E4-B45F-0A4C4EF7D9FC" />
    </application>
</manifest>
