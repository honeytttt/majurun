# Local properties for Android build
# Copy this file to local.properties and fill in your values
# DO NOT commit local.properties to version control!

# Android SDK path (auto-generated by Flutter/Android Studio)
sdk.dir=/path/to/Android/Sdk
flutter.sdk=/path/to/flutter

# Google Maps API Key for Android
# Get from: https://console.cloud.google.com/apis/credentials
# Restrictions:
#   - Application: Android apps
#   - Package: com.majurun.app
#   - SHA-1: (from ./gradlew signingReport)
#   - API: Maps SDK for Android
MAPS_API_KEY=YOUR_ANDROID_MAPS_API_KEY_HERE
