rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Primary: Firebase Custom Claim. Fallback: known admin email (safety net).
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.get('admin', false) == true ||
        request.auth.token.email == 'majurun.app@gmail.com'
      );
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    // Entitlement fields are written ONLY by the verifySubscription Cloud
    // Function (which uses the Admin SDK and bypasses these rules). Any client
    // update that touches one of these keys is rejected.
    function entitlementFields() {
      return ['isPro', 'subscriptionType', 'subscriptionExpiry',
              'entitlementSource', 'lastVerifiedAt'];
    }
    function clientUpdateRespectsEntitlement() {
      // Allowed when the diff between request and existing data does NOT
      // touch any entitlement field. Admin still bypasses below.
      return !request.resource.data.diff(resource.data)
                .affectedKeys()
                .hasAny(entitlementFields());
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isOwner(userId) && clientUpdateRespectsEntitlement())
      );
      allow delete: if isAdmin();

      // followers/{followerId} — the follower document represents followerId following userId.
      // Only the follower themselves may add/remove their own record.
      match /followers/{followerId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(followerId);
      }

      // following/{followingId} — only the account owner manages who they follow.
      match /following/{followingId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }

      match /training_history/{historyId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /blockedUsers/{blockedUserId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /routes/{routeId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /shoes/{shoeId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /savedPosts/{postId} {
        allow read, write: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /dailyChallenges/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /weeklyChallenges/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /monthlyChallenges/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /runHistory/{runId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /settings/{settingId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ─── User privacy ─────────────────────────────────────────────────────────
    match /userPrivacy/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ─── Posts ────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isAuthenticated();

      // Creator must own the document; required fields must be present; content size-capped.
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'content', 'createdAt']) &&
        request.resource.data.content is string &&
        request.resource.data.content.size() <= 2000;

      // Owner can edit all fields; any auth user may update only likes/comments counters.
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments']) ||
        isAdmin()
      );

      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      // Comments
      match /comments/{commentId} {
        allow read: if isAuthenticated();

        allow create: if isAuthenticated() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.keys().hasAll(['userId', 'content', 'createdAt']) &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 1000;

        allow update, delete: if isAuthenticated() &&
          (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    // Parent doc holds per-user counters (unread, last seen). Only the owner
    // may read or write the parent — the previous open-write rule let any
    // signed-in user spoof another user's unread state. Items subcollection
    // keeps its own per-sender check below so other users can still create
    // notification rows for the owner (likes, comments, follows, etc.).
    match /notifications/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      match /items/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated() &&
          request.resource.data.keys().hasAll(['type', 'senderId', 'createdAt']) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.type in ['follow', 'like', 'comment', 'mention', 'badge', 'dm', 'post', 'reminder'] &&
          userId != request.auth.uid;
        allow update, delete: if isOwner(userId);
      }
    }

    // ─── Notification settings ────────────────────────────────────────────────
    match /userNotificationSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── Conversations / DMs ──────────────────────────────────────────────────
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update, delete: if isAuthenticated() &&
          resource.data.senderId == request.auth.uid;
      }
    }

    // ─── Events ───────────────────────────────────────────────────────────────
    // Events are admin-managed content; authenticated users may only read.
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ─── Challenges ───────────────────────────────────────────────────────────
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Contact messages ─────────────────────────────────────────────────────
    match /contactMessages/{messageId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // ─── IAP transactions ledger ──────────────────────────────────────────────
    // Written ONLY by the verifySubscription Cloud Function (Admin SDK bypasses
    // these rules). Clients must never see or write here.
    match /iapTransactions/{txId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── App logs ─────────────────────────────────────────────────────────────
    // Size-capped to prevent log-flooding abuse.
    match /app_logs/{logId} {
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['level', 'message', 'userId', 'timestamp']) &&
        request.resource.data.message is string &&
        request.resource.data.message.size() <= 2000;
      allow read, delete: if isAdmin();
    }
  }
}
