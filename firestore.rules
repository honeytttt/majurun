rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if user is admin
    // Admin email: majurun.app@gmail.com
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'majurun.app@gmail.com';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow users to create/update their own document, admin can update any
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      // User's followers subcollection
      match /followers/{followerId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      // User's following subcollection
      match /following/{followingId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      // User's training history subcollection
      match /training_history/{historyId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      // User's blocked users subcollection
      match /blockedUsers/{blockedUserId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // User's saved routes subcollection
      match /routes/{routeId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      // User's shoes subcollection
      match /shoes/{shoeId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      // User's saved posts subcollection (bookmarks)
      match /savedPosts/{postId} {
        allow read, write: if isOwner(userId);
      }

      // User's goals subcollection
      match /goals/{goalId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      // User's daily/weekly/monthly challenges
      match /dailyChallenges/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      match /weeklyChallenges/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      match /monthlyChallenges/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // User's run history subcollection
      match /runHistory/{runId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isAdmin();
      }

      // User's settings subcollection (voice, notifications, etc.)
      match /settings/{settingId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // User privacy settings collection
    match /userPrivacy/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments']) ||
         isAdmin());

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // Notifications collection - user's personal notifications
    match /notifications/{userId} {
      allow read: if isOwner(userId);
      allow write: if isAuthenticated();

      match /items/{notificationId} {
        allow read: if isOwner(userId);
        // Any authenticated user can create a notification for another user
        // (required for follow/like/comment social interactions)
        allow create: if isAuthenticated() &&
          request.resource.data.keys().hasAll(['type', 'senderId', 'createdAt']) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.type in ['follow', 'like', 'comment', 'mention', 'badge', 'dm', 'post', 'reminder'];
        allow update, delete: if isOwner(userId); // Only owner can modify/delete
      }
    }

    // User notification settings (bell subscriptions)
    match /userNotificationSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Conversations collection - DM
    match /conversations/{conversationId} {
      // Allow read/write only if user is a participant
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update, delete: if isAuthenticated() &&
          resource.data.senderId == request.auth.uid;
      }
    }

    // Events collection (if exists)
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Challenges collection
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isAdmin();
      allow delete: if isAdmin();
    }

    // Contact messages collection
    match /contactMessages/{messageId} {
      allow create: if isAuthenticated(); // Anyone can submit a contact form
      allow read, update, delete: if isAdmin(); // Only admin can view/manage
    }

    // App logs collection — written by any authenticated app user, read only by admin
    match /app_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, delete: if isAdmin();
    }
  }
}
